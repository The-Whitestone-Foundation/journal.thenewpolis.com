---
permalink: /feed/firehose.xml
eleventyExcludeFromCollections: true
layout: false
---
{% set siteUrl = metadata.url | htmlBaseUrl %}
<?xml version="1.0" encoding="utf-8"?>
<?xml-stylesheet href="/feed/pretty-atom-feed.xsl" type="text/xsl"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ metadata.title }} Firehose</title>
  <subtitle>{{ metadata.description }}</subtitle>
  <link href="{{ '/feed/firehose.xml' | htmlBaseUrl(siteUrl) }}" rel="self"/>
  <link href="{{ '/' | htmlBaseUrl(siteUrl) }}"/>
  <updated>{{ page.date.toISOString() }}</updated>
  <id>{{ '/' | htmlBaseUrl(siteUrl) }}</id>
  <author>
    <name>{{ metadata.author.name }}</name>
  </author>
  {%- for post in collections.all | reverse %}
    {%- if post.url and post.url != permalink and post.data.title and loop.index0 < 100 %}
    <entry>
      <title>{{ post.data.title }}</title>
      <link href="{{ post.url | htmlBaseUrl(siteUrl) }}"/>
      <updated>{{ post.date.toISOString() }}</updated>
      <id>{{ post.url | htmlBaseUrl(siteUrl) }}</id>
      <content type="html"><![CDATA[
        {{ post.content | safe }}
      ]]></content>
    </entry>
    {%- endif %}
  {%- endfor %}
</feed>
