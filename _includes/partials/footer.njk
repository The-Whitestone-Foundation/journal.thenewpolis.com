<footer class="text-center py-5">
    <div class="container">
        <p class="small">
            © {{ metadata.footer.year_start }}-{{ "" | luxonNow("yyyy", "America/Chicago") }} {{ metadata.footer.text }}
        </p>
        <p class="small fw-bold border-top border-secondary pt-3 d-inline-block text-uppercase" 
           style="letter-spacing: 2px; color: #666;">
            <a href="{{ metadata.footer.url }}" class="text-white">{{ metadata.footer.info }}</a>
            <br/>
            <span style="font-size: 0.8rem;">
                {% for publication in metadata.footer.publications %}
                    <a class="text-white" href="{{ publication.url }}" target="_blank" rel="noopener noreferrer">{{ publication.title }}</a>{% if not loop.last %} | {% endif %}
                {% endfor %}
            </span>
            <br/>
            <small>
                built with <a class="text-white" href="https://11ty.dev" target="_blank">{{ eleventy.generator }}</a> 
                | managed by <a class="text-white" href="{{ metadata.footer.manager.url }}" target="_blank" rel="noopener noreferrer">{{ metadata.footer.manager.name }}</a>
            </small>
        </p>
    </div>
</footer>
