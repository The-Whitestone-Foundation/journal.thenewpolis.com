<script type="application/ld+json" data-no-bundle>
{% set siteUrl = metadata.url | htmlBaseUrl %}
{
  "@context": "https://schema.org",
  "@type": "NGO",
  "@id": "{{ '/' | htmlBaseUrl(siteUrl) }}",
  "name": "{{ metadata.title }}",
  "url": "{{ '/' | htmlBaseUrl(siteUrl) }}",
  "logo": "{{ metadata.favicon | htmlBaseUrl(siteUrl) }}",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Boulder",
    "addressRegion": "CO",
    "addressCountry": "US"
  }
}
</script>

{% if page.url %}
  {% set isArchive = ("/archives/" in page.url) %}
  {% set isJournal = (metadata.title == "Journal New Polis") %}
  
  <script type="application/ld+json" data-no-bundle>
  {
    "@context": "https://schema.org",
    "@type": "{% if isArchive or isJournal %}ScholarlyArticle{% else %}BlogPosting{% endif %}",
    "headline": "{{ title or metadata.title }}",
    "description": "{{ description or metadata.description or '' }}",
    "datePublished": "{{ date or page.date }}",
    "author": {
      "@type": "Person",
      "name": "{{ authors or author or metadata.author.name or 'Whitestone Staff' }}"
    },
    "publisher": {
      "@type": "Organization",
      "name": "{{ metadata.title }}",
      "url": "{{ '/' | htmlBaseUrl(siteUrl) }}"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "{{ page.url | htmlBaseUrl(siteUrl) }}"
    }
  }
  </script>
{% endif %}

{% if page.url != "/" %}
<script type="application/ld+json" data-no-bundle>
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ '/' | htmlBaseUrl(siteUrl) }}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{ title or 'Article' }}",
      "item": "{{ page.url | htmlBaseUrl(siteUrl) }}"
    }
  ]
}
</script>
{% endif %}
