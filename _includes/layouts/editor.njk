---
layout: layouts/base.njk
---
<main class="container my-5">
    <header class="text-center mb-5 pb-5 border-bottom">
        <h1 class="display-4 serif fw-bold mb-3 p-name">{{ title }}</h1>
        {% if description %}
        <p class="lead text-secondary serif italic">{{ description }}</p>
        {% endif %}
    </header>

    <div class="e-content mx-auto" style="max-width: 780px;">
        {{ content | safe }}
    </div>
</main>

<style>
    .serif { font-family: 'Georgia', serif; }
    .italic { font-style: italic; }
</style>
